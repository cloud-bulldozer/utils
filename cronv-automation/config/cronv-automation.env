# Cron Visualization Automation - Environment Configuration
#
# This file is sourced by on-sync.sh. Edit values here to customize
# the automation without modifying scripts.

# Path where nginx serves the HTML visualization
NGINX_HTML_PATH=/var/www/html/crontab.html

# cronv visualization settings
CRONV_DURATION=31d
CRONV_TITLE="Periodic CI Jobs"
CRONV_WIDTH=150

# git-sync settings (used by the systemd service)
GIT_SYNC_PERIOD=300s
REPO_URL=https://github.com/openshift/release.git
REPO_REF=main

# Base directory for the automation (where this repo is cloned on the target host)
AUTOMATION_DIR=/opt/cronv-automation

# Directory where the web UI static files are served by nginx
# NGINX_WEB_DIR is derived from NGINX_HTML_PATH by default
# Override if the web app is served from a different location
# NGINX_WEB_DIR=/usr/share/nginx/html
